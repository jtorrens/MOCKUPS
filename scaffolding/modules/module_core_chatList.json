{
  "schemaVersion": 1,
  "intent": {
    "responsibility": "Own the reusable Screen that presents the Chat App conversation list.",
    "visualBoundary": "Compose Status Bar and Navigation Bar around one fill Component Stack whose top and bottom Icon Bars bound a central List viewport.",
    "runtimeBehavior": "Expose the List Chats Variant Runtime Inputs and item collection without renaming, reducing or duplicating them.",
    "forwarding": "Promote the exact List input ids itemWidth and itemHeight plus the exact items collection into the Module Runtime contract; keep system chrome and Icon Bar content Variant-owned.",
    "temporalOwnership": "The Screen owns its duration and transition; List owns collection presence and reflow; List Item owns item Motion and internal state.",
    "productionContext": "Resolve only through the exact Production Screen to Shot owner Actor to Theme and Device context."
  },
