{
  "name": "mockups",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "validate:examples": "tsx src/domain/validation/validateExamples.ts",
    "validate:resolver": "tsx src/domain/validation/validateResolver.ts",
    "check:architecture": "tsx scripts/checkDesktopPreviewArchitecture.ts",
    "db:init": "tsx src/persistence/sqlite/initializeDevelopmentDatabase.ts",
    "db:seed": "tsx src/persistence/sqlite/seedDevelopmentDatabase.ts",
    "db:reset": "tsx src/persistence/sqlite/resetDevelopmentDatabase.ts",
    "icon-theme:import": "tsx src/icon-themes/importDevelopmentIconTheme.ts",
    "validate:sqlite": "tsx src/persistence/sqlite/validateSQLiteRepository.ts",
    "audit:current-model": "tsx src/persistence/audit/auditCurrentModel.ts",
    "db:normalize-current-model": "tsx src/persistence/audit/normalizeCurrentModel.ts",
    "desktop-preview:build": "node scripts/buildDesktopPreview.mjs",
    "desktop": "dotnet run --project spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj",
    "desktop:build": "dotnet build spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj",
    "desktop:publish:mac": "npm run desktop-preview:build && dotnet publish spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj -c Release -r osx-arm64 --self-contained true -o out/desktop/osx-arm64",
    "desktop:package:mac": "npm run desktop:publish:mac && node scripts/packageMacApp.mjs",
    "desktop:publish:win": "npm run desktop-preview:build && dotnet publish spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj -c Release -r win-x64 --self-contained true -o out/desktop/win-x64",
    "app": "npm run desktop",
    "app:check": "npm run desktop:build",
    "app:build": "npm run desktop:build",
    "test": "npm run typecheck && npm run check:architecture && npm run validate:examples && npm run validate:resolver && npm run validate:sqlite"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
