{
  "name": "mockups",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "check:unused:desktop": "dotnet format spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj style --verify-no-changes --severity info --diagnostics IDE0060 --no-restore",
    "check:architecture": "tsx scripts/checkDesktopPreviewArchitecture.ts",
    "legacy:icon-theme:import": "tsx archive/react-legacy/src/icon-themes/importDevelopmentIconTheme.ts",
    "legacy:validate:examples": "tsx archive/react-legacy/src/domain/validation/validateExamples.ts",
    "legacy:validate:resolver": "tsx archive/react-legacy/src/domain/validation/validateResolver.ts",
    "legacy:validate:sqlite": "tsx archive/react-legacy/src/persistence/sqlite/validateSQLiteRepository.ts",
    "legacy:db:init": "tsx archive/react-legacy/src/persistence/sqlite/initializeDevelopmentDatabase.ts",
    "legacy:db:seed": "tsx archive/react-legacy/src/persistence/sqlite/seedDevelopmentDatabase.ts",
    "legacy:db:reset": "tsx archive/react-legacy/src/persistence/sqlite/resetDevelopmentDatabase.ts",
    "legacy:audit:current-model": "tsx archive/react-legacy/src/persistence/audit/auditCurrentModel.ts",
    "legacy:db:normalize-current-model": "tsx archive/react-legacy/src/persistence/audit/normalizeCurrentModel.ts",
    "desktop-preview:build": "node scripts/buildDesktopPreview.mjs",
    "desktop-preview:svg": "tsx scripts/renderDesignPreviewSvg.ts",
    "desktop": "dotnet run --project spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj",
    "desktop:build": "dotnet build spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj",
    "desktop:db:create": "dotnet run --project spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj -- --create-current-database",
    "desktop:db:validate": "dotnet run --project spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj -- --validate-current-database",
    "desktop:publish:mac": "npm run desktop-preview:build && dotnet publish spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj -c Release -r osx-arm64 --self-contained true -o out/desktop/osx-arm64",
    "desktop:package:mac": "npm run desktop:publish:mac && node scripts/packageMacApp.mjs",
    "desktop:publish:win": "npm run desktop-preview:build && dotnet publish spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj -c Release -r win-x64 --self-contained true -o out/desktop/win-x64",
    "app": "npm run desktop",
    "app:check": "npm run desktop:build",
    "app:build": "npm run desktop:build",
    "animation:test:preview": "tsx --test tests/animation/*.test.ts",
    "animation:test:desktop": "dotnet run --project spikes/desktop-editor-shell-animation-tests/Mockups.DesktopEditorShell.AnimationTests.csproj",
    "animation:test": "npm run animation:test:preview && npm run animation:test:desktop",
    "test": "npm run desktop-preview:build && npm run typecheck && npm run desktop:build && npm run check:unused:desktop && npm run animation:test && npm run check:architecture",
    "test:cold": "dotnet clean spikes/desktop-editor-shell/Mockups.DesktopEditorShell.csproj && npm test"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "fontkit": "^2.0.4",
    "playwright": "^1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fontkit": "^2.0.9",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
