<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:editor="using:Mockups.DesktopEditorShell.EditorShell"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
                 x:Class="Mockups.DesktopEditorShell.MainWindow"
                 Title="Mockups Desktop Editor Shell · codex/editor-modernization-rules · v0.212.0"
                 Width="1440"
                 Height="900"
                 MinWidth="1040"
                 MinHeight="680"
                 IsMenuVisible="False"
                 BackgroundAnimationEnabled="False"
                 BackgroundTransitionsEnabled="False"
                 BackgroundTransitionTime="0.05">
    <Grid Margin="10" RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Padding="18,12">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="SPIKE / DESKTOP EDITOR SHELL · codex/editor-modernization-rules · v0.211.0" />
                    <TextBlock FontSize="17" FontWeight="Bold" Text="Three resizable panels · shared light/dark palette" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="UsageRefreshButton"
                            Click="OnRefreshUsageClick"
                            Content="Update usage" />
                    <TextBlock x:Name="ThemeLabel"
                               VerticalAlignment="Center"
                               Text="Dark mode" />
                    <Button x:Name="ThemeToggleButton"
                            Click="OnToggleThemeClick"
                            Content="Switch to light" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ShellColumns"
              Grid.Row="1"
              ColumnDefinitions="320,6,2*,6,*">
            <Border Grid.Column="0" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="NAVIGATION" />
                            <TextBlock FontSize="17" FontWeight="Bold" Text="Production tree" />
                        </StackPanel>
                    </Border>
                    <ScrollViewer Padding="10">
                        <StackPanel x:Name="NavigationCardsPanel" Spacing="10" />
                    </ScrollViewer>
                    </DockPanel>
                </suki:GlassCard>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="2" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="EDITOR" />
                                <StackPanel x:Name="EditorBreadcrumbPanel"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            VerticalAlignment="Center" />
                                <TextBlock x:Name="EditorPresetTextBlock"
                                           FontSize="12"
                                           Opacity="0.74"
                                           IsVisible="False" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ScrollViewer x:Name="EditorScrollViewer"
                                  Padding="22">
                        <StackPanel x:Name="EditorCardsPanel" Spacing="10" />
                    </ScrollViewer>
                    </DockPanel>
                </suki:GlassCard>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="4" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="WEB PREVIEW" />
                            <TextBlock FontSize="17" FontWeight="Bold" Text="Runtime stays web" />
                        </StackPanel>
                    </Border>
                    <Grid Margin="22"
                          RowDefinitions="Auto,Auto,*"
                          RowSpacing="14">
                        <Border Grid.Row="0"
                                Padding="12"
                                CornerRadius="12"
                                Background="#22000000">
                            <Grid ColumnDefinitions="*,*,Auto,Auto,Auto"
                                  ColumnSpacing="10">
                                <StackPanel Spacing="8">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="DEVICE" />
                                    <editor:EditorInstantComboBox x:Name="PreviewDeviceComboBox"
                                                                  MinHeight="36"
                                                                  HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Spacing="8">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="THEME" />
                                    <editor:EditorInstantComboBox x:Name="PreviewThemeComboBox"
                                                                  MinHeight="36"
                                                                  HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            Spacing="8"
                                            MinWidth="112">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="MODE" />
                                    <editor:EditorInstantComboBox x:Name="PreviewModeComboBox"
                                                                  MinHeight="36"
                                                                  HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="3"
                                            Spacing="8"
                                            MinWidth="104">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="SCALE" />
                                    <editor:EditorInstantComboBox x:Name="PreviewScaleComboBox"
                                                                  MinHeight="36"
                                                                  HorizontalAlignment="Stretch" />
                                </StackPanel>
                                <StackPanel Grid.Column="4"
                                            Spacing="8"
                                            MinWidth="88">
                                    <TextBlock FontSize="11"
                                               FontWeight="SemiBold"
                                               Text="MARKS" />
                                    <ToggleSwitch x:Name="PreviewMarksToggle"
                                                  IsChecked="True"
                                                  VerticalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Grid.Row="1"
                                Padding="10,6"
                                CornerRadius="8"
                                Background="#14000000">
                            <TextBox x:Name="ShellMessagesTextBox"
                                     MinHeight="30"
                                     MaxHeight="96"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Text="No messages" />
                        </Border>
                        <TabControl Grid.Row="2">
                            <TabItem Header="Preview">
                                <Border Padding="12"
                                        CornerRadius="12"
                                        Background="#18000000">
                                    <ContentControl x:Name="RuntimePreviewHost" />
                                </Border>
                            </TabItem>
                            <TabItem Header="Design">
                                <Border Padding="12"
                                        CornerRadius="12"
                                        Background="#18000000">
                                    <ContentControl x:Name="DesignPreviewHost" />
                                </Border>
                            </TabItem>
                        </TabControl>
                    </Grid>
                    </DockPanel>
                </suki:GlassCard>
            </Border>
        </Grid>
    </Grid>
</suki:SukiWindow>
