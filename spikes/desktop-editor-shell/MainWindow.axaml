<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:editor="using:Mockups.DesktopEditorShell.EditorShell"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
                 x:Class="Mockups.DesktopEditorShell.MainWindow"
        Title="Mockups Desktop Editor Shell · Design / Production · v0.317.46"
                 Width="1440"
                 Height="900"
                 MinWidth="1040"
                 MinHeight="680"
                 IsMenuVisible="False"
                 BackgroundStyle="Flat"
                 BackgroundAnimationEnabled="False"
                 BackgroundTransitionsEnabled="False"
                 BackgroundTransitionTime="0.05">
    <Border x:Name="RootShell" Padding="10">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Padding="18,12">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Spacing="4">
                    <Border x:Name="WorkspaceSwitcherBorder"
                            Width="268"
                            Height="40"
                            CornerRadius="10"
                            BorderThickness="1"
                            HorizontalAlignment="Left"
                            ClipToBounds="True">
                        <Grid ColumnDefinitions="*,*">
                        <Button x:Name="DesignWorkspaceButton"
                                Grid.Column="0"
                                Content="Design"
                                MinHeight="38"
                                FontSize="17"
                                FontWeight="Bold"
                                Padding="18,4"
                                BorderThickness="0"
                                CornerRadius="0" />
                        <Button x:Name="ProductionWorkspaceButton"
                                Grid.Column="1"
                                Content="Production"
                                MinHeight="38"
                                FontSize="17"
                                FontWeight="Bold"
                                Padding="18,4"
                                BorderThickness="0"
                                CornerRadius="0" />
                        </Grid>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="UsageRefreshButton"
                            Click="OnRefreshUsageClick"
                            MinHeight="36"
                            Padding="10,4"
                            BorderThickness="0" />
                    <Button x:Name="ShellSettingsButton"
                            Click="OnShellSettingsClick"
                            Width="38"
                            Height="36"
                            Padding="0"
                            BorderThickness="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ShellColumns"
              Grid.Row="1"
              ColumnDefinitions="320,6,2*,6,*">
            <Border Grid.Column="0" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="NAVIGATION" />
                            <TextBlock x:Name="NavigationWorkspaceTextBlock" FontSize="17" FontWeight="Bold" Text="Design" />
                            <Grid x:Name="ProductionPickerGrid"
                                  ColumnDefinitions="*,Auto"
                                  ColumnSpacing="6"
                                  IsVisible="False"
                                  Margin="0,8,0,0">
                                <editor:EditorInstantComboBox x:Name="ProductionComboBox"
                                                              Grid.Column="0"
                                                              MinHeight="34" />
                                <Button x:Name="ProductionEditButton"
                                        Grid.Column="1"
                                        Width="30"
                                        Height="34"
                                        Padding="0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        BorderBrush="Transparent" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Padding="10">
                        <StackPanel x:Name="NavigationCardsPanel" Spacing="10" />
                    </ScrollViewer>
                    </DockPanel>
                </suki:GlassCard>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="2" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="22,16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="EDITOR" />
                                <StackPanel x:Name="EditorBreadcrumbPanel"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            VerticalAlignment="Center" />
                                <StackPanel x:Name="EditorContextStripHost"
                                            Margin="0,4,0,0"
                                            IsVisible="False" />
                            </StackPanel>
                            <StackPanel x:Name="EditorHeaderActionsPanel"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top" />
                        </Grid>
                    </Border>
                    <ScrollViewer x:Name="EditorScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="22">
                        <StackPanel x:Name="EditorCardsPanel"
                                    Spacing="10"
                                    HorizontalAlignment="Stretch" />
                    </ScrollViewer>
                    </DockPanel>
                </suki:GlassCard>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="4" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="PREVIEW" />
                            <StackPanel x:Name="PreviewTitlePanel"
                                        Orientation="Horizontal"
                                        Spacing="4" />
                        </StackPanel>
                    </Border>
                    <Grid x:Name="PreviewPanelGrid"
                          Margin="22"
                          RowDefinitions="240,10,*,Auto">
                        <Border Grid.Row="0"
                                MinHeight="132"
                                Padding="8"
                                CornerRadius="12"
                                Background="#18000000">
                            <TabControl x:Name="PreviewUtilityTabs"
                                        HorizontalContentAlignment="Stretch"
                                        VerticalContentAlignment="Stretch">
                                <TabItem x:Name="PreviewAuthoringDataTab"
                                         Header="Test Values"
                                         IsVisible="False">
                                    <ContentControl x:Name="PreviewAuthoringDataHost"
                                                    HorizontalContentAlignment="Stretch"
                                                    VerticalContentAlignment="Stretch" />
                                </TabItem>
                                <TabItem x:Name="PreviewSetupTab"
                                         Header="Preview Setup">
                                    <ContentControl x:Name="PreviewSetupHost">
                                        <StackPanel Spacing="10">
                                            <Grid ColumnDefinitions="*,*,Auto,Auto"
                                                  ColumnSpacing="10">
                                                <StackPanel Spacing="8">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Text="DEVICE" />
                                                    <editor:EditorInstantComboBox x:Name="PreviewDeviceComboBox"
                                                                                  MinHeight="36"
                                                                                  HorizontalAlignment="Stretch" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Spacing="8">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Text="THEME" />
                                                    <editor:EditorInstantComboBox x:Name="PreviewThemeComboBox"
                                                                                  MinHeight="36"
                                                                                  HorizontalAlignment="Stretch" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2"
                                                            Spacing="8"
                                                            MinWidth="112">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Text="MODE" />
                                                    <editor:EditorInstantComboBox x:Name="PreviewModeComboBox"
                                                                                  MinHeight="36"
                                                                                  HorizontalAlignment="Stretch" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="3"
                                                            Spacing="8"
                                                            MinWidth="132">
                                                    <TextBlock FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Text="ORIENTATION" />
                                                    <editor:EditorInstantComboBox x:Name="PreviewOrientationComboBox"
                                                                                  MinHeight="36"
                                                                                  HorizontalAlignment="Stretch" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </ContentControl>
                                </TabItem>
                                <TabItem x:Name="PreviewControlsTab"
                                         Header="Preview Controls">
                                    <ContentControl x:Name="PreviewControlsHost" />
                                </TabItem>
                            </TabControl>
                        </Border>
                        <GridSplitter x:Name="PreviewUtilitySplitter"
                                      Grid.Row="1"
                                      Height="6"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Center"
                                      ResizeDirection="Rows"
                                      ResizeBehavior="PreviousAndNext" />
                        <Grid Grid.Row="2"
                              MinHeight="180"
                              Margin="0,14,0,14"
                              RowDefinitions="Auto,*"
                              RowSpacing="6">
                            <Border Padding="10,6"
                                    CornerRadius="8"
                                    Background="#12000000">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Current frame"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="PreviewContextTextBlock"
                                                   MaxWidth="240"
                                                   VerticalAlignment="Center"
                                                   FontSize="12"
                                                   Opacity="0.82"
                                                   TextTrimming="CharacterEllipsis"
                                                   IsVisible="False" />
                                        <Button x:Name="PreviewContextHistoryButton"
                                                Width="26"
                                                Height="28"
                                                Padding="0"
                                                Content="v"
                                                FontWeight="Bold"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center" />
                                        <Button x:Name="PreviewContextAddHistoryButton"
                                                Width="26"
                                                Height="28"
                                                Padding="0"
                                                Content="+"
                                                FontWeight="Bold"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center" />
                                        <Button x:Name="PreviewContextLockButton"
                                                Width="30"
                                                Height="28"
                                                Padding="0"
                                                HorizontalContentAlignment="Center"
                                                VerticalContentAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <Border Grid.Row="1"
                                    Padding="12"
                                    CornerRadius="12"
                                    Background="#18000000">
                                <Grid>
                                    <ContentControl x:Name="DesignPreviewHost" />
                                    <ContentControl x:Name="PreviewBusyHost"
                                                    ZIndex="100"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch"
                                                    IsVisible="False" />
                                </Grid>
                            </Border>
                        </Grid>
                        <Border Grid.Row="3"
                                Padding="10,6"
                                CornerRadius="8"
                                Background="#14000000">
                            <TextBox x:Name="ShellMessagesTextBox"
                                     MinHeight="30"
                                     MaxHeight="96"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Text="No messages" />
                        </Border>
                    </Grid>
                    </DockPanel>
                </suki:GlassCard>
            </Border>
        </Grid>
    </Grid>
    </Border>
</suki:SukiWindow>
