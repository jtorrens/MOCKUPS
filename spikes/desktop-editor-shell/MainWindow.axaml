<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:editor="using:Mockups.DesktopEditorShell.EditorShell"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
                 x:Class="Mockups.DesktopEditorShell.MainWindow"
                 Title="Mockups Desktop Editor Shell · codex/editor-modernization-rules · v0.272.0"
                 Width="1440"
                 Height="900"
                 MinWidth="1040"
                 MinHeight="680"
                 IsMenuVisible="False"
                 BackgroundStyle="Flat"
                 BackgroundAnimationEnabled="False"
                 BackgroundTransitionsEnabled="False"
                 BackgroundTransitionTime="0.05">
    <Border x:Name="RootShell" Padding="10">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Padding="18,12">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="SPIKE / DESKTOP EDITOR SHELL · codex/editor-modernization-rules · v0.272.0" />
                    <TextBlock FontSize="17" FontWeight="Bold" Text="Three resizable panels · shared light/dark palette" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button x:Name="UsageRefreshButton"
                            Click="OnRefreshUsageClick"
                            Content="Update usage" />
                    <Button x:Name="ShellSettingsButton"
                            Click="OnShellSettingsClick"
                            Width="38"
                            Height="36"
                            Padding="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ShellColumns"
              Grid.Row="1"
              ColumnDefinitions="320,6,2*,6,*">
            <Border Grid.Column="0" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="NAVIGATION" />
                            <TextBlock FontSize="17" FontWeight="Bold" Text="Production tree" />
                        </StackPanel>
                    </Border>
                    <ScrollViewer Padding="10">
                        <StackPanel x:Name="NavigationCardsPanel" Spacing="10" />
                    </ScrollViewer>
                    </DockPanel>
                </suki:GlassCard>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="2" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="22,16">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <StackPanel Spacing="4">
                                <TextBlock FontSize="11" FontWeight="SemiBold" Text="EDITOR" />
                                <StackPanel x:Name="EditorBreadcrumbPanel"
                                            Orientation="Horizontal"
                                            Spacing="4"
                                            VerticalAlignment="Center" />
                                <TextBlock x:Name="EditorPresetTextBlock"
                                           FontSize="12"
                                           Opacity="0.74"
                                           IsVisible="False" />
                            </StackPanel>
                            <StackPanel x:Name="EditorHeaderActionsPanel"
                                        Grid.Column="1"
                                        Orientation="Horizontal"
                                        Spacing="6"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top" />
                        </Grid>
                    </Border>
                    <ScrollViewer x:Name="EditorScrollViewer"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  Padding="22">
                        <StackPanel x:Name="EditorCardsPanel"
                                    Spacing="10"
                                    HorizontalAlignment="Stretch" />
                    </ScrollViewer>
                    </DockPanel>
                </suki:GlassCard>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="4" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="WEB PREVIEW" />
                            <TextBlock FontSize="17" FontWeight="Bold" Text="Runtime stays web" />
                        </StackPanel>
                    </Border>
                    <Grid Margin="22"
                          RowDefinitions="Auto,*,Auto"
                          RowSpacing="14">
                        <ContentControl x:Name="PreviewSetupHost"
                                        Grid.Row="0">
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*,*,Auto,Auto"
                                      ColumnSpacing="10">
                                    <StackPanel Spacing="8">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="DEVICE" />
                                        <editor:EditorInstantComboBox x:Name="PreviewDeviceComboBox"
                                                                      MinHeight="36"
                                                                      HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Spacing="8">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="THEME" />
                                        <editor:EditorInstantComboBox x:Name="PreviewThemeComboBox"
                                                                      MinHeight="36"
                                                                      HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2"
                                                Spacing="8"
                                                MinWidth="112">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="MODE" />
                                        <editor:EditorInstantComboBox x:Name="PreviewModeComboBox"
                                                                      MinHeight="36"
                                                                      HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="3"
                                                Spacing="8"
                                                MinWidth="132">
                                        <TextBlock FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Text="ORIENTATION" />
                                        <editor:EditorInstantComboBox x:Name="PreviewOrientationComboBox"
                                                                      MinHeight="36"
                                                                      HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Grid>
                                <ContentControl x:Name="PreviewInputsHost" />
                            </StackPanel>
                        </ContentControl>
                        <Grid Grid.Row="1">
                            <TabControl SelectedIndex="1">
                                <TabItem Header="Preview">
                                    <Border Padding="12"
                                            CornerRadius="12"
                                            Background="#18000000">
                                        <ContentControl x:Name="RuntimePreviewHost" />
                                    </Border>
                                </TabItem>
                                <TabItem Header="Design">
                                    <Border Padding="12"
                                            CornerRadius="12"
                                            Background="#18000000">
                                        <ContentControl x:Name="DesignPreviewHost" />
                                    </Border>
                                </TabItem>
                            </TabControl>
                            <Border HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Margin="0,3,8,0"
                                    Padding="8,0"
                                    Background="#12000000"
                                    CornerRadius="8">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="PreviewContextTextBlock"
                                               MaxWidth="240"
                                               VerticalAlignment="Center"
                                               FontSize="12"
                                               Opacity="0.82"
                                               TextTrimming="CharacterEllipsis"
                                               IsVisible="False" />
                                    <Button x:Name="PreviewContextLockButton"
                                            Width="30"
                                            Height="28"
                                            Padding="0"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Grid.Row="2"
                                Padding="10,6"
                                CornerRadius="8"
                                Background="#14000000">
                            <TextBox x:Name="ShellMessagesTextBox"
                                     MinHeight="30"
                                     MaxHeight="96"
                                     AcceptsReturn="True"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Text="No messages" />
                        </Border>
                    </Grid>
                    </DockPanel>
                </suki:GlassCard>
            </Border>
        </Grid>
    </Grid>
    </Border>
</suki:SukiWindow>
