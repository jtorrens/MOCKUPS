<suki:SukiWindow xmlns="https://github.com/avaloniaui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:suki="clr-namespace:SukiUI.Controls;assembly=SukiUI"
                 mc:Ignorable="d" d:DesignWidth="1440" d:DesignHeight="900"
                 x:Class="Mockups.DesktopEditorShell.MainWindow"
                 Title="Mockups Desktop Editor Shell"
                 Width="1440"
                 Height="900"
                 MinWidth="1040"
                 MinHeight="680"
                 IsMenuVisible="False"
                 BackgroundAnimationEnabled="False">
    <Grid Margin="10" RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Padding="18,12">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock FontSize="11" FontWeight="SemiBold" Text="SPIKE / DESKTOP EDITOR SHELL" />
                    <TextBlock FontSize="17" FontWeight="Bold" Text="Three resizable panels · shared light/dark palette" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock x:Name="ThemeLabel"
                               VerticalAlignment="Center"
                               Text="Dark mode" />
                    <Button x:Name="ThemeToggleButton"
                            Click="OnToggleThemeClick"
                            Content="Switch to light" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ShellColumns"
              Grid.Row="1"
              ColumnDefinitions="320,6,2*,6,*">
            <Border Grid.Column="0" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="NAVIGATION" />
                            <TextBlock FontSize="17" FontWeight="Bold" Text="Production tree" />
                        </StackPanel>
                    </Border>
                    <ScrollViewer Padding="10">
                        <StackPanel x:Name="NavigationCardsPanel" Spacing="10" />
                    </ScrollViewer>
                    </DockPanel>
                </suki:GlassCard>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="2" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="EDITOR" />
                            <TextBlock x:Name="EditorTitle"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       Text="Dictionary-driven property editor" />
                        </StackPanel>
                    </Border>
                    <ScrollViewer Padding="22">
                        <StackPanel x:Name="EditorCardsPanel" Spacing="10" />
                    </ScrollViewer>
                    </DockPanel>
                </suki:GlassCard>
            </Border>

            <GridSplitter Grid.Column="3"
                          Width="6"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext" />

            <Border Grid.Column="4" Margin="10">
                <suki:GlassCard>
                    <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Padding="18,16">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="11" FontWeight="SemiBold" Text="WEB PREVIEW" />
                            <TextBlock FontSize="17" FontWeight="Bold" Text="Runtime stays web" />
                        </StackPanel>
                    </Border>
                    <Grid Margin="22">
                        <Border Width="270"
                                Height="560"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                BorderBrush="{DynamicResource PreviewDeviceBorderBrush}"
                                BorderThickness="8"
                                CornerRadius="34"
                                Background="{DynamicResource PreviewDeviceBackground}">
                            <Grid RowDefinitions="70,*">
                                <Border Grid.Row="0"
                                        Background="{DynamicResource PreviewHeaderBackground}"
                                        CornerRadius="26,26,0,0"
                                        Padding="18,14">
                                    <StackPanel>
                                        <TextBlock Foreground="{DynamicResource PreviewHeaderTextBrush}"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Text="Alex" />
                                        <TextBlock Foreground="{DynamicResource PreviewHeaderMutedBrush}"
                                                   FontSize="12"
                                                   Text="offline" />
                                    </StackPanel>
                                </Border>
                                <Grid Grid.Row="1"
                                      Background="{DynamicResource PreviewScreenBackground}">
                                    <StackPanel Margin="18,34,18,0" Spacing="12">
                                        <Border HorizontalAlignment="Right"
                                                MaxWidth="210"
                                                CornerRadius="18"
                                                Background="{DynamicResource PreviewOutgoingBubble}"
                                                Padding="14,10">
                                            <TextBlock Foreground="{DynamicResource PreviewBubbleTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="Are you close?" />
                                        </Border>
                                        <Border HorizontalAlignment="Left"
                                                MaxWidth="220"
                                                CornerRadius="18"
                                                Background="{DynamicResource PreviewIncomingBubble}"
                                                Padding="14,10">
                                            <TextBlock Foreground="{DynamicResource PreviewIncomingTextBrush}"
                                                       TextWrapping="Wrap"
                                                       Text="Two minutes away." />
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                    </DockPanel>
                </suki:GlassCard>
            </Border>
        </Grid>
    </Grid>
</suki:SukiWindow>
