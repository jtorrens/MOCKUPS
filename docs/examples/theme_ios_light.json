{
  "id": "theme_ios_light",
  "production_id": "production_demo",
  "name": "iOS Light",
  "family": "ios",
  "version": "1.0.0",
  "tokens_json": {
    "defaultMode": "light",
    "modes": {
      "light": {
        "colors": {
          "background": "white",
          "textPrimary": "black",
          "textSecondary": "gray_medium",
          "accent": "blue"
        },
        "statusBar": {
          "type": "ios-default",
          "foreground": "black",
          "background": "rgba(255,255,255,0)"
        },
        "navigationBar": {
          "type": "ios-home-indicator",
          "foreground": "black",
          "background": "rgba(255,255,255,0)"
        },
        "keyboard": {
          "background": "keyboard_light_background",
          "keyBackground": "white",
          "specialKeyBackground": "keyboard_light_special",
          "pressedKeyBackground": "gray",
          "popoverBackground": "white",
          "text": "black"
        },
        "notifications": {
          "background": "rgba(245,245,247,0.92)",
          "titleColor": "black",
          "bodyColor": "gray_deep"
        }
      },
      "dark": {
        "colors": {
          "background": "black",
          "textPrimary": "white",
          "textSecondary": "gray_medium_bright",
          "accent": "blue_bright"
        },
        "statusBar": {
          "type": "ios-default",
          "foreground": "white",
          "background": "rgba(0,0,0,0)"
        },
        "navigationBar": {
          "type": "ios-home-indicator",
          "foreground": "white",
          "background": "rgba(0,0,0,0)"
        },
        "keyboard": {
          "background": "keyboard_dark_background",
          "keyBackground": "keyboard_dark_key",
          "specialKeyBackground": "gray_deep",
          "pressedKeyBackground": "gray",
          "popoverBackground": "keyboard_dark_key",
          "text": "white"
        },
        "notifications": {
          "background": "rgba(44,44,46,0.92)",
          "titleColor": "white",
          "bodyColor": "gray_soft"
        }
      }
    },
    "fonts": {
      "family": "SF Pro Text",
      "bodySize": 17,
      "bodyLineHeight": 21.25,
      "captionSize": 13,
      "weight": "Regular",
      "source": "installed_system_font"
    },
    "colors": {
      "background": "white",
      "textPrimary": "black",
      "textSecondary": "gray_medium",
      "accent": "blue"
    },
    "statusBar": {
      "type": "ios-default",
      "foreground": "black",
      "background": "rgba(255,255,255,0)",
      "iconScale": 1
    },
    "navigationBar": {
      "type": "ios-home-indicator",
      "foreground": "black",
      "background": "rgba(255,255,255,0)",
      "iconScale": 1
    },
    "keyboard": {
      "background": "keyboard_light_background",
      "keyBackground": "white",
      "specialKeyBackground": "keyboard_light_special",
      "pressedKeyBackground": "gray",
      "popoverBackground": "white",
      "text": "black"
    },
    "notifications": {
      "backdropBlur": 24
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24
    },
    "radii": {
      "notification": 16,
      "card": 12
    },
    "shadows": {
      "avatar": {
        "color": "rgba(0,0,0,0.18)",
        "offsetX": 0,
        "offsetY": 4,
        "blur": 18
      },
      "elevated": {
        "color": "rgba(0,0,0,0.18)",
        "offsetX": 0,
        "offsetY": 4,
        "blur": 18
      }
    }
  }
}
