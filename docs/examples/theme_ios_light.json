{
  "id": "theme_ios_light",
  "production_id": "production_demo",
  "name": "iOS Light",
  "family": "ios",
  "version": "1.0.0",
  "tokens_json": {
    "defaultMode": "light",
    "modes": {
      "light": {
        "colors": {
          "background": "gray_100",
          "textPrimary": "gray_000",
          "textSecondary": "gray_040",
          "accent": "blue",
          "icons.primary": "gray_000",
          "icons.secondary": "gray_040",
          "icons.accent": "blue",
          "borders.primary": "gray_080",
          "borders.secondary": "gray_070",
          "borders.alternate": "gray_090"
        },
        "statusBar": {
          "type": "ios-default",
          "foreground": "gray_000",
          "background": {
            "color": "gray_100",
            "alpha": 0
          }
        },
        "navigationBar": {
          "type": "ios-home-indicator",
          "foreground": "gray_000",
          "background": {
            "color": "gray_100",
            "alpha": 0
          }
        },
        "keyboard": {
          "background": "gray_080",
          "keyBackground": "gray_100",
