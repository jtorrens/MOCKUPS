        "notifications": {
          "background": {
            "color": "gray_020",
            "alpha": 0.92
          },
          "titleColor": "gray_100",
          "bodyColor": "gray_080"
        }
      }
    },
    "fonts": {
      "family": "SF Pro Text",
      "bodySize": 17,
      "bodyLineHeight": 21.25,
      "captionSize": 13,
      "weight": "Regular",
      "source": "production_font"
    },
    "colors": {
      "background": "gray_100",
      "textPrimary": "gray_000",
      "textSecondary": "gray_040",
      "accent": "blue",
      "icons.primary": "gray_000",
      "icons.secondary": "gray_040",
      "icons.accent": "blue",
      "borders.primary": "gray_080",
      "borders.secondary": "gray_070",
      "borders.alternate": "gray_090"
    },
    "statusBar": {
      "type": "ios-default",
      "foreground": "gray_000",
      "background": {
        "color": "gray_100",
        "alpha": 0
      },
      "iconScale": 1
    },
    "navigationBar": {
      "type": "ios-home-indicator",
      "foreground": "gray_000",
      "background": {
        "color": "gray_100",
        "alpha": 0
      },
      "iconScale": 1
    },
    "keyboard": {
      "background": "gray_080",
      "keyBackground": "gray_100",
      "specialKeyBackground": "gray_070",
      "pressedKeyBackground": "gray_060",
      "popoverBackground": "gray_100",
      "text": "gray_000"
    },
    "notifications": {
      "backdropBlur": 24
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24
    },
    "radii": {
      "notification": 16,
      "card": 12
    },
    "shadows": {
      "avatar": {
        "color": {
          "color": "gray_000",
          "alpha": 0.18
        },
        "offsetX": 0,
        "offsetY": 4,
        "blur": 18
      },
      "elevated": {
        "color": {
          "color": "gray_000",
          "alpha": 0.18
        },
        "offsetX": 0,
        "offsetY": 4,
        "blur": 18
      }
    },
    "surfaceRelief": {
      "default": {
        "angleDeg": -45,
        "extension": 1,
        "spread": 0,
        "upperIntensity": 0.1,
        "lowerIntensity": -0.08
      }
    }
