        "notifications": {
          "background": {
            "color": "gray_090",
            "alpha": 0.92
          },
          "titleColor": "gray_000",
          "bodyColor": "gray_020"
        }
      },
      "dark": {
        "colors": {
          "background": "gray_000",
          "textPrimary": "gray_100",
          "textSecondary": "gray_060",
          "accent": "blue_bright",
          "icons.primary": "gray_000",
          "icons.secondary": "gray_040",
          "icons.accent": "blue",
          "borders.primary": "gray_080",
          "borders.secondary": "gray_070",
          "borders.alternate": "gray_090"
        },
        "statusBar": {
          "type": "ios-default",
          "foreground": "gray_100",
          "background": {
            "color": "gray_000",
            "alpha": 0
          }
        },
        "navigationBar": {
          "type": "ios-home-indicator",
          "foreground": "gray_100",
          "background": {
            "color": "gray_000",
            "alpha": 0
          }
        },
        "keyboard": {
          "background": "gray_020",
          "keyBackground": "gray_040",
          "specialKeyBackground": "gray_020",
          "pressedKeyBackground": "gray_060",
          "popoverBackground": "gray_040",
          "text": "gray_100"
