{
  "id": "theme_ios_light",
  "production_id": "production_demo",
  "name": "iOS Light",
  "family": "ios",
  "version": "1.0.0",
  "tokens_json": {
    "defaultMode": "light",
    "fontSelection": {
      "family": "SF Pro Text",
      "style": "normal",
      "weight": 400,
      "source": "installed_system_font"
    },
    "modes": {
      "light": {
        "colors": {
          "background": "#FFFFFF",
          "textPrimary": "#000000",
          "textSecondary": "#6E6E73",
          "accent": "#007AFF"
        },
        "statusBar": {
          "foreground": "#000000",
          "background": "transparent"
        }
      },
      "dark": {
        "colors": {
          "background": "#000000",
          "textPrimary": "#FFFFFF",
          "textSecondary": "#98989D",
          "accent": "#0A84FF"
        },
        "statusBar": {
          "foreground": "#FFFFFF",
          "background": "transparent"
        }
      }
    },
    "fonts": {
      "family": "SF Pro Text",
      "bodySize": 17,
      "bodyLineHeight": 21.25,
      "captionSize": 13,
      "weightRegular": 400,
      "weightSemibold": 600
    },
    "colors": {
      "background": "#FFFFFF",
      "textPrimary": "#000000",
      "textSecondary": "#6E6E73",
      "accent": "#007AFF"
    },
    "statusBar": {
      "foreground": "#000000",
      "background": "transparent",
      "iconScale": 1
    },
    "notifications": {
      "background": "rgba(245,245,247,0.92)",
      "titleColor": "#000000",
      "bodyColor": "#3A3A3C",
      "backdropBlur": 24
    },
    "spacing": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24
    },
    "radii": {
      "notification": 16,
      "card": 12
    },
    "shadows": {
      "notification": {
        "color": "rgba(0,0,0,0.18)",
        "offsetX": 0,
        "offsetY": 4,
        "blur": 18
      }
    }
  }
}
